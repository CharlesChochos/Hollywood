# ===========================================
# AI Hollywood Studio — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL=postgresql://hollywood:hollywood@localhost:5432/hollywood

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- S3 / MinIO ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hollywood-assets
S3_REGION=us-east-1

# ---- Auth (Auth.js v5) ----
AUTH_SECRET=change-me-to-a-random-secret-in-production
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# NEXT_PUBLIC_GITHUB_AUTH_ENABLED=true

# ---- AI Providers (all optional — mock providers used when not set) ----
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# STABILITY_API_KEY=
# ELEVENLABS_API_KEY=
# RUNWAY_API_KEY=

# ---- Realtime (Socket.io) ----
REALTIME_PORT=3001
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# ---- Observability (optional) ----
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---- App ----
NODE_ENV=development
PORT=3000
